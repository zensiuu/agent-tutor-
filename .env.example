# =============================================================================
# Tunisian Tutor v2.0 - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your API keys
# NEVER commit .env.local or .env files to version control

# =============================================================================
# AI Brain (HuggingFace) - REQUIRED
# =============================================================================
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# =============================================================================
# Web Search (Tavily) - REQUIRED
# =============================================================================
# Get your key at: https://tavily.com (1000 credits/month free)
TAVILY_API_KEY=tvly_your_api_key_here

# =============================================================================
# Voice Transcription (Deepgram) - REQUIRED
# =============================================================================
# Get your key at: https://deepgram.com (200 min/month free)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# =============================================================================
# Vector Memory (Pinecone) - REQUIRED
# =============================================================================
# Get your key at: https://pinecone.io (1M vectors free)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_URL=https://your-index.svc.pinecone.io

# =============================================================================
# REMOVED
# =============================================================================
# GROQ_API_KEY - No longer used (replaced by HuggingFace)
# TINYFISH_API_KEY - No longer used (replaced by Tavily)
